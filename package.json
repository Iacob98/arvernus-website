{
  "name": "arvernus-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -p 3030",
    "lint": "eslint",
    "loadtest:pages": "k6 run -e BASE_URL=http://localhost:3000 -e LOADTEST_SECRET=loadtest-secret-dev load-tests/k6/scenarios/page-load.js",
    "loadtest:contact": "k6 run -e BASE_URL=http://localhost:3000 -e LOADTEST_SECRET=loadtest-secret-dev load-tests/k6/scenarios/contact-submit.js",
    "loadtest:rechner": "k6 run -e BASE_URL=http://localhost:3000 -e LOADTEST_SECRET=loadtest-secret-dev load-tests/k6/scenarios/rechner-submit.js",
    "loadtest:mixed": "k6 run -e BASE_URL=http://localhost:3000 -e LOADTEST_SECRET=loadtest-secret-dev load-tests/k6/scenarios/mixed-load.js",
    "loadtest:sustained": "k6 run -e BASE_URL=http://localhost:3000 -e LOADTEST_SECRET=loadtest-secret-dev load-tests/k6/scenarios/sustained-ramp.js",
    "loadtest:verify": "npx tsx load-tests/verify-integrity.ts",
    "loadtest:full": "npm run loadtest:contact && npm run loadtest:verify -- --expected-contact 50 && npm run loadtest:mixed && npm run loadtest:verify"
  },
  "dependencies": {
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "jose": "^6.1.3",
    "motion": "^12.34.0",
    "next": "16.1.6",
    "nodemailer": "^8.0.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.7.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.9",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "playwright": "^1.58.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
